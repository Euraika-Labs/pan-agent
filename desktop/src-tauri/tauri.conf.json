{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pan Desktop",
  "version": "0.1.0",
  "identifier": "net.euraika.pandesktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Pan Desktop",
        "width": 1200,
        "height": 800,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8642; style-src 'self' 'unsafe-inline'; img-src 'self' data:; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Euraika-Labs/pan-agent/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0RUE3NUI4RkI5NzYwNjYKUldSbVlKZjd1SFhxdERoUDBPRzVtVWtHbkNZWDJQNW1UOFlmWlBwdHd2ajZIbFNhclRzY0o5WFEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/pan-agent"
    ],
    "windows": {
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "wix": {}
    }
  }
}
