{
  "name": "pan-desktop",
  "version": "0.6.6",
  "description": "Pan Desktop — Tauri desktop app for Pan-Agent",
  "productName": "Pan Desktop",
  "author": "Euraika Labs",
  "homepage": "https://git.euraika.net/euraika/pan-agent",
  "repository": {
    "type": "git",
    "url": "https://git.euraika.net/euraika/pan-agent.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:tauri\"",
    "dev:vite": "vite",
    "dev:tauri": "tauri dev",
    "build": "npm run build:vite && npm run build:tauri",
    "build:vite": "tsc -noEmit && vite build",
    "build:tauri": "tauri build",
    "check:tauri": "cargo check --manifest-path src-tauri/Cargo.toml",
    "tauri": "tauri",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
